{
  "expo": {
    "name": "ClothMeasure",
    "slug": "clothmeasure",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "clothmeasure",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.clothmeasure.app",
      "infoPlist": {
        "NSCameraUsageDescription": "ClothMeasure potrzebuje dostępu do kamery, aby fotografować ubrania i dokonywać ich pomiarów.",
        "NSPhotoLibraryUsageDescription": "ClothMeasure potrzebuje dostępu do galerii, aby zapisywać i importować zdjęcia z pomiarami.",
        "NSPhotoLibraryAddUsageDescription": "ClothMeasure zapisze zdjęcia z pomiarami do Twojej galerii."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A1A",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.clothmeasure.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "ClothMeasure potrzebuje dostępu do kamery do fotografowania ubrań."
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "ClothMeasure potrzebuje dostępu do kamery, aby fotografować ubrania i dokonywać ich pomiarów.",
          "enableCameraPermission": true
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "ClothMeasure zapisuje zdjęcia z pomiarami do galerii.",
          "savePhotosPermission": "ClothMeasure zapisuje zdjęcia z pomiarami do galerii.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9187fc75-f4ec-4c4d-8623-6a7797c2d598"
      }
    },
    "owner": "n-e-s"
  }
}
